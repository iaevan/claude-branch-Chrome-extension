{
  "manifest_version": 3,
  "name": "Claude Branch Chat",
  "version": "1.0.4",
  "description": "Branch any Claude conversation from any message into a new chat with full context",
  "permissions": ["tabs", "scripting", "clipboardWrite"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Claude Branch Chat"
  }
}
